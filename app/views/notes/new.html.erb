<% content_for :title, "New note" %>

<h1>New note</h1>

<% if @note.errors.any? %>
  <ul>
    <% @note.errors.full_messages.each do |msg| %>
      <li style="color: red;"><%= msg %></li>
    <% end %>
  </ul>
<% end %>


<%= render "form", note: @note %>

<br>

<div>
  <%= link_to "Back to notes", notes_path %>
</div>
