<p style="color: green"><%= notice %></p>

<% content_for :title, "Simon's Notes" %>

<h1 class="text-6xl font-extrabold p-8 text-blue-500 shadow-md mb-6">MY NOTES</h1>

<% if @notes.any? %>
  <div id="notes">
    <% @notes.each do |note| %>
      <%= render note %>
      <p><%= link_to "Show this note", note %></p>
    <% end %>
  </div>
<% else %>
  <p style="color: gray;">📭 No pinned notes found. Try pinning one!</p>
<% end %>


<%= link_to "New note", new_note_path %>
